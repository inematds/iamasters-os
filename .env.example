# iAmasters OS — Environment Variables Template
# Copia este ficheiro para .env e preenche os valores que usares.
# .env NUNCA é commitado (está no .gitignore).

# ============================================================
# OPCIONAL — só se fores usar a skill que precisa
# ============================================================

# Firecrawl: para fazer scraping do teu site/LinkedIn/YouTube e extrair voice samples + brand assets
# Sem isto, a skill marketing-brand-voice usa o fetch nativo (limitado)
# Como: regista-te em https://www.firecrawl.dev (500 créditos free) e copia a tua API key
FIRECRAWL_API_KEY=

# YouTube API (opcional): para tool-youtube-transcript com metadados extra
# Sem isto, usa-se whisper local ou transcript público
YOUTUBE_API_KEY=

# OpenAI (opcional): se usares Whisper API para transcrições longas em vez de mlx-whisper local
OPENAI_API_KEY=

# ============================================================
# NÃO necessárias para o Claude Code
# ============================================================
# Anthropic NÃO se põe aqui: o Claude Code usa o teu plano Pro/Max desde o login.
# A API só se usares alguma skill que chame o Anthropic SDK direto (raro neste repo).
# ANTHROPIC_API_KEY=

# ============================================================
# Para multi-cliente com APIs específicas (opcional)
# ============================================================
# Se um cliente usa GoHighLevel/HubSpot/Notion e tens uma skill que liga
GHL_API_KEY=
HUBSPOT_API_KEY=
NOTION_API_KEY=
